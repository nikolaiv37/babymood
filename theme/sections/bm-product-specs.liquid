{% liquid
  assign section_id = 'bm-product-specs-' | append: section.id
  assign mattress_size = product.metafields.custom.mattress_size.value | default: product.metafields.custom.mattress_size
  assign material = product.metafields.custom.material.value | default: product.metafields.custom.material
  assign product_color = product.metafields.custom.color.value | default: product.metafields.custom.color
  assign dimensions = product.metafields.custom.dimensions.value | default: product.metafields.custom.dimensions
  assign suitable_age = product.metafields.custom.suitable_age.value | default: product.metafields.custom.suitable_age
  assign whats_included = product.metafields.custom.whats_included.value | default: product.metafields.custom.whats_included
%}

{% if mattress_size != blank
  or material != blank
  or product_color != blank
  or dimensions != blank
  or suitable_age != blank
  or whats_included != blank
%}
  <section
    id="{{ section_id }}"
    class="bm-product-specs color-{{ section.settings.color_scheme }} gradient"
  >
    <div class="bm-product-specs__container">
      <div class="bm-product-specs__header">
        {% if section.settings.heading != blank %}
          <h2 class="bm-product-specs__heading">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.subheading != blank %}
          <p class="bm-product-specs__subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>

      <dl class="bm-product-specs__grid">
        {% if mattress_size != blank %}
          <div class="bm-product-specs__item">
            <dt class="bm-product-specs__label">
              <span class="bm-product-specs__mark" aria-hidden="true"></span>
              Размер на матрак
            </dt>
            <dd class="bm-product-specs__value">{{ mattress_size }}</dd>
          </div>
        {% endif %}

        {% if material != blank %}
          <div class="bm-product-specs__item">
            <dt class="bm-product-specs__label">
              <span class="bm-product-specs__mark" aria-hidden="true"></span>
              Материал
            </dt>
            <dd class="bm-product-specs__value">{{ material }}</dd>
          </div>
        {% endif %}

        {% if product_color != blank %}
          <div class="bm-product-specs__item">
            <dt class="bm-product-specs__label">
              <span class="bm-product-specs__mark" aria-hidden="true"></span>
              Цвят
            </dt>
            <dd class="bm-product-specs__value">{{ product_color }}</dd>
          </div>
        {% endif %}

        {% if dimensions != blank %}
          <div class="bm-product-specs__item">
            <dt class="bm-product-specs__label">
              <span class="bm-product-specs__mark" aria-hidden="true"></span>
              Размери
            </dt>
            <dd class="bm-product-specs__value">{{ dimensions }}</dd>
          </div>
        {% endif %}

        {% if suitable_age != blank %}
          <div class="bm-product-specs__item">
            <dt class="bm-product-specs__label">
              <span class="bm-product-specs__mark" aria-hidden="true"></span>
              Подходящо за
            </dt>
            <dd class="bm-product-specs__value">{{ suitable_age }}</dd>
          </div>
        {% endif %}

        {% if whats_included != blank %}
          <div class="bm-product-specs__item bm-product-specs__item--wide">
            <dt class="bm-product-specs__label">
              <span class="bm-product-specs__mark" aria-hidden="true"></span>
              Какво е включено
            </dt>
            <dd class="bm-product-specs__value">{{ whats_included | newline_to_br }}</dd>
          </div>
        {% endif %}
      </dl>
    </div>
  </section>
{% endif %}

{% style %}
  #{{ section_id }} {
    --bm-specs-ink: #2f2a26;
    --bm-specs-yellow: #ffd801;
    --bm-specs-border: #efe6c8;
    --bm-specs-surface: #ffffff;
    --bm-specs-surface-soft: #fffdf5;
    --bm-specs-muted: rgba(47, 42, 38, 0.68);
    padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px;
    color: var(--bm-specs-ink);
  }

  #{{ section_id }} .bm-product-specs__container {
    border: 1px solid var(--bm-specs-border);
    border-radius: 24px;
    background:
      linear-gradient(180deg, var(--bm-specs-surface-soft) 0%, #fff8e8 100%),
      var(--bm-specs-surface-soft);
    box-shadow: 0 10px 26px rgba(47, 42, 38, 0.04);
    padding: clamp(1rem, 3vw, 1.5rem);
  }

  #{{ section_id }} .bm-product-specs__header {
    max-width: 42rem;
    margin-bottom: clamp(0.8rem, 2vw, 1.05rem);
  }

  #{{ section_id }} .bm-product-specs__heading {
    margin: 0;
    color: var(--bm-specs-ink);
    font-size: clamp(1.3rem, 2.8vw, 1.9rem);
    line-height: 1.14;
    font-weight: 750;
    letter-spacing: 0;
  }

  #{{ section_id }} .bm-product-specs__subheading {
    margin: 0.45rem 0 0;
    color: var(--bm-specs-muted);
    font-size: clamp(0.95rem, 1.7vw, 1rem);
    line-height: 1.48;
    letter-spacing: 0;
  }

  #{{ section_id }} .bm-product-specs__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.7rem;
    margin: 0;
    border: 0;
    background: transparent;
  }

  #{{ section_id }} .bm-product-specs__item {
    display: grid;
    align-content: start;
    gap: 0.38rem;
    min-height: 100%;
    padding: 0.85rem 0.9rem;
    border: 1px solid rgba(239, 230, 200, 0.9);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.88);
    box-shadow: 0 6px 14px rgba(47, 42, 38, 0.035);
  }

  #{{ section_id }} .bm-product-specs__label {
    display: inline-flex;
    align-items: center;
    gap: 0.48rem;
    margin: 0;
    color: rgba(47, 42, 38, 0.72);
    font-size: 0.72rem;
    line-height: 1.2;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  #{{ section_id }} .bm-product-specs__mark {
    display: inline-block;
    width: 0.48rem;
    height: 0.48rem;
    border-radius: 999px;
    background: var(--bm-specs-yellow);
    box-shadow: none;
    flex: 0 0 auto;
  }

  #{{ section_id }} .bm-product-specs__value {
    margin: 0;
    color: var(--bm-specs-ink);
    font-size: 1rem;
    line-height: 1.42;
    font-weight: 700;
    letter-spacing: 0;
  }

  @media screen and (min-width: 750px) {
    #{{ section_id }} .bm-product-specs__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.8rem;
    }

    #{{ section_id }} .bm-product-specs__item--wide {
      grid-column: 1 / -1;
    }
  }

  @media screen and (min-width: 990px) {
    #{{ section_id }} .bm-product-specs__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Baby Mood product specs",
  "tag": "section",
  "class": "section section-bm-product-specs",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Детайли за продукта"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Важна информация за размери, материали и употреба."
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Baby Mood product specs"
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
