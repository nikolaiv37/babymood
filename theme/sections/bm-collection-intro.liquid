{% liquid
  assign section_id = 'bm-collection-intro-' | append: section.id
  assign heading = section.settings.heading | default: collection.title
%}

<section
  id="{{ section_id }}"
  class="bm-collection-intro color-{{ section.settings.color_scheme }} gradient"
>
  <div class="bm-collection-intro__inner">
    <div class="bm-collection-intro__copy">
      {% if heading != blank %}
        <h1 class="bm-collection-intro__heading">{{ heading }}</h1>
      {% endif %}

      {% if section.settings.kicker != blank %}
        <p class="bm-collection-intro__kicker">{{ section.settings.kicker }}</p>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="bm-collection-intro__text rte">
          {{ section.settings.text }}
        </div>
      {% elsif collection.description != blank %}
        <div class="bm-collection-intro__text rte">
          {{ collection.description }}
        </div>
      {% endif %}
    </div>

    <div class="bm-collection-intro__chips" aria-label="{{ 'Колекция предимства' | escape }}">
      {% for block in section.blocks %}
        {% if block.settings.text != blank %}
          <div class="bm-collection-intro__chip" {{ block.shopify_attributes }}>
            <span class="bm-collection-intro__chip-dot" aria-hidden="true"></span>
            <span>{{ block.settings.text }}</span>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% style %}
  #{{ section_id }} {
    --bm-collection-ink: #2f2a26;
    --bm-collection-muted: rgba(47, 42, 38, 0.72);
    --bm-collection-yellow: #ffd801;
    --bm-collection-border: #efe6c8;
    --bm-collection-cream: #fffdf5;
    padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px;
    color: var(--bm-collection-ink);
  }

  #{{ section_id }} .bm-collection-intro__inner {
    width: min(var(--page-width), calc(100% - 2rem));
    margin-inline: auto;
    padding: clamp(0.95rem, 2.3vw, 1.35rem);
    border: 1px solid var(--bm-collection-border);
    border-radius: 22px;
    background:
      radial-gradient(circle at 94% 18%, rgba(255, 216, 1, 0.12), transparent 26%),
      linear-gradient(180deg, var(--bm-collection-cream), #ffffff);
  }

  #{{ section_id }} .bm-collection-intro__copy {
    max-width: 54rem;
  }

  #{{ section_id }} .bm-collection-intro__heading {
    margin: 0;
    color: var(--bm-collection-ink);
    font-size: clamp(1.7rem, 4.2vw, 3rem);
    line-height: 1.05;
    letter-spacing: 0;
  }

  #{{ section_id }} .bm-collection-intro__kicker {
    margin: 0.55rem 0 0;
    color: var(--bm-collection-ink);
    font-size: clamp(1rem, 2vw, 1.22rem);
    line-height: 1.3;
    font-weight: 750;
    letter-spacing: 0;
  }

  #{{ section_id }} .bm-collection-intro__text {
    max-width: 44rem;
    margin-top: 0.32rem;
    color: var(--bm-collection-muted);
    font-size: clamp(0.93rem, 1.6vw, 1rem);
    line-height: 1.48;
  }

  #{{ section_id }} .bm-collection-intro__text p {
    margin-block: 0;
  }

  #{{ section_id }} .bm-collection-intro__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.42rem;
    margin-top: clamp(0.72rem, 2vw, 0.95rem);
  }

  #{{ section_id }} .bm-collection-intro__chip {
    display: inline-flex;
    align-items: center;
    gap: 0.38rem;
    min-height: 1.72rem;
    padding: 0.32rem 0.58rem;
    border: 1px solid rgba(239, 230, 200, 0.68);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.48);
    color: var(--bm-collection-ink);
    font-size: 0.8rem;
    line-height: 1.2;
    font-weight: 600;
  }

  #{{ section_id }} .bm-collection-intro__chip-dot {
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 999px;
    background: var(--bm-collection-yellow);
    flex: 0 0 auto;
  }

  @media screen and (min-width: 750px) {
    #{{ section_id }} .bm-collection-intro__inner {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: end;
      gap: 0.95rem;
    }

    #{{ section_id }} .bm-collection-intro__chips {
      justify-content: flex-end;
      max-width: 22rem;
      margin-top: 0;
    }
  }

  body:has(#{{ section_id }}) .product-grid product-card .product-grid__card {
    background: transparent;
    border: 0;
    box-shadow: none;
  }

  body:has(#{{ section_id }}) .product-grid product-card .card-gallery {
    border-radius: 20px;
    background:
      linear-gradient(180deg, rgba(255, 253, 245, 0.98), rgba(255, 250, 228, 0.72));
    box-shadow:
      inset 0 0 0 1px rgba(239, 230, 200, 0.32),
      0 8px 18px rgba(47, 42, 38, 0.03);
  }

  body:has(#{{ section_id }}) .product-grid product-card product-price:not(.bm-product-price) [ref='priceContainer'] {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.14rem 0.42rem;
  }

  body:has(#{{ section_id }}) .product-grid product-card product-price:not(.bm-product-price) .price {
    color: #2f2a26;
    font-size: 0.96rem;
    line-height: 1.15;
    font-weight: 720;
  }

  body:has(#{{ section_id }}) .product-grid product-card product-price:not(.bm-product-price) .price-item--sale {
    color: #2f2a26;
  }

  body:has(#{{ section_id }}) .product-grid product-card product-price:not(.bm-product-price) .compare-at-price {
    color: rgba(47, 42, 38, 0.58);
    font-size: 0.82rem;
    font-weight: 550;
    text-decoration: line-through;
    text-decoration-color: rgba(47, 42, 38, 0.34);
    text-decoration-thickness: 0.07em;
  }

  body:has(#{{ section_id }}) .product-grid product-card product-price:not(.bm-product-price) .bm-product-price__saving {
    display: block;
    width: auto;
    margin-top: 0.08rem;
    padding: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    color: rgba(126, 88, 22, 0.82);
    font-size: 0.74rem;
    line-height: 1.15;
    font-weight: 620;
  }

  body:has(#{{ section_id }}) .product-grid product-card .product-badges__badge {
    border: 0;
    background: #2f2a26;
    color: #fffdf5;
    box-shadow: none;
  }
{% endstyle %}

{% schema %}
{
  "name": "BM collection intro",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Intro heading",
      "default": "Монтесори легла за спокойна детска стая"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Intro text",
      "default": "<p>Подбрани ниски легла, които насърчават самостоятелност, удобство и по-спокойна вечерна рутина.</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "chip",
      "name": "Trust chip",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Безопасен избор"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BM collection intro",
      "blocks": [
        {
          "type": "chip",
          "settings": {
            "text": "Безопасен избор"
          }
        },
        {
          "type": "chip",
          "settings": {
            "text": "Консултация преди покупка"
          }
        },
        {
          "type": "chip",
          "settings": {
            "text": "Безплатна доставка до офис на Еконт"
          }
        }
      ]
    }
  ]
}
{% endschema %}
