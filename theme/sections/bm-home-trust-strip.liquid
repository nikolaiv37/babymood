{% liquid
  assign section_id = 'bm-home-trust-strip-' | append: section.id
%}

<section
  id="{{ section_id }}"
  class="bm-home-trust-strip color-{{ section.settings.color_scheme }} gradient"
>
  <div class="bm-home-trust-strip__inner">
    {% if section.settings.section_heading != blank %}
      <h2 class="bm-home-trust-strip__title">{{ section.settings.section_heading }}</h2>
    {% endif %}

    <div class="bm-home-trust-strip__grid">
      {% for block in section.blocks %}
        <div class="bm-home-trust-strip__item" {{ block.shopify_attributes }}>
          <div class="bm-home-trust-strip__icon" aria-hidden="true">
            {% case block.settings.icon %}
              {% when 'leaf' %}
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M20 4.5c-6.2.2-10.7 2-13.2 5.3-2 2.7-2.2 6.1-.7 8.6 2.8-5.2 7.1-8 12.4-8.9-5.1 1.9-8.7 5.1-10.8 9.7 2.7 1.5 6.4 1.1 9.1-1.4 3.2-3 4.1-8.1 3.2-13.3Z" />
                </svg>
              {% when 'chat' %}
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M6.8 18.2 4 20v-3.3A7.6 7.6 0 0 1 2 11.5C2 7.4 6 4 11 4s9 3.4 9 7.5S16 19 11 19c-1.5 0-3-.3-4.2-.8Zm.6-3.1.5.3c.9.5 2 .8 3.1.8 3.5 0 6.2-2.1 6.2-4.7S14.5 6.8 11 6.8s-6.2 2.1-6.2 4.7c0 1.3.6 2.5 1.8 3.4l.5.4v1l.3-.2Z" />
                </svg>
              {% when 'return' %}
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M12 4a8 8 0 1 1-7.2 11.5l2.4-1.1A5.4 5.4 0 1 0 7.4 9h2.1v2.6H3V5.1h2.6v2A8 8 0 0 1 12 4Zm1.2 4v4.2l3.1 1.8-1.2 2-4.3-2.5V8h2.4Z" />
                </svg>
              {% when 'delivery' %}
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M3 5h11.7v3.1h2.7l3.6 4.2v5.2h-2.3a3 3 0 0 1-5.8 0H9.7a3 3 0 0 1-5.8 0H3V5Zm2.4 2.4V15h.2a3 3 0 0 1 4.1 0h4.9V7.4H5.4Zm11.7 3.1V15h1.5v-1.8l-2.3-2.7h.8ZM6.8 18.6a.9.9 0 1 0 0-1.8.9.9 0 0 0 0 1.8Zm9 0a.9.9 0 1 0 0-1.8.9.9 0 0 0 0 1.8Z" />
                </svg>
              {% when 'shield' %}
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M12 2.8 20 6v5.6c0 5-3.3 8.5-8 9.8-4.7-1.3-8-4.8-8-9.8V6l8-3.2Zm0 2.6L6.4 7.6v4c0 3.6 2.2 6.1 5.6 7.2 3.4-1.1 5.6-3.6 5.6-7.2v-4L12 5.4Zm3.9 5.2-4.8 4.8-2.8-2.8 1.6-1.6 1.2 1.2 3.2-3.2 1.6 1.6Z" />
                </svg>
              {% when 'star' %}
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="m12 3.4 2.6 5.3 5.9.9-4.3 4.2 1 5.9L12 16.9l-5.3 2.8 1-5.9L3.5 9.6l5.9-.9L12 3.4Z" />
                </svg>
            {% endcase %}
          </div>

          <div class="bm-home-trust-strip__content">
            {% if block.settings.heading != blank %}
              <h3 class="bm-home-trust-strip__heading">{{ block.settings.heading }}</h3>
            {% endif %}

            {% if block.settings.text != blank %}
              <p class="bm-home-trust-strip__text">{{ block.settings.text }}</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% style %}
  #{{ section_id }} {
    --bm-tstrip-ink: #2a2520;
    --bm-tstrip-muted: rgba(42, 37, 32, 0.72);
    --bm-tstrip-yellow: #ffd801;
    --bm-tstrip-card: #fffdf6;
    --bm-tstrip-card-warm: #fff7e0;
    --bm-tstrip-border: #efe6c8;
    --bm-tstrip-border-soft: rgba(239, 230, 200, 0.7);
    --bm-tstrip-dot: rgba(255, 216, 1, 0.4);
    --bm-tstrip-gap: clamp(0.7rem, 2vw, 1rem);
    padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px;
    padding-inline: clamp(12px, 4vw, 28px);
    color: var(--bm-tstrip-ink);
  }

  #{{ section_id }} .bm-home-trust-strip__inner {
    max-width: 1400px;
    margin: 0 auto;
  }

  #{{ section_id }} .bm-home-trust-strip__title {
    margin: 0 0 1rem;
    font-size: clamp(1.1rem, 2.2vw, 1.3rem);
    line-height: 1.2;
    font-weight: 720;
    letter-spacing: -0.005em;
    color: var(--bm-tstrip-ink);
    text-align: center;
  }

  #{{ section_id }} .bm-home-trust-strip__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--bm-tstrip-gap);
  }

  #{{ section_id }} .bm-home-trust-strip__item {
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: start;
    gap: 0.9rem;
    min-width: 0;
    padding: 1.05rem 1.1rem;
    border: 1px solid var(--bm-tstrip-border-soft);
    border-radius: 20px;
    background:
      radial-gradient(circle at 100% 0%, rgba(255, 216, 1, 0.14), transparent 38%),
      linear-gradient(180deg, #ffffff, var(--bm-tstrip-card));
    transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.22s ease;
  }

  #{{ section_id }} .bm-home-trust-strip__item:hover {
    transform: translateY(-1px);
    border-color: #e6d9a6;
    box-shadow: 0 6px 16px rgba(255, 216, 1, 0.1);
  }

  #{{ section_id }} .bm-home-trust-strip__item::after {
    content: "";
    position: absolute;
    top: 0.7rem;
    right: 0.85rem;
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 999px;
    background: var(--bm-tstrip-dot);
    pointer-events: none;
  }

  #{{ section_id }} .bm-home-trust-strip__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.55rem;
    height: 2.55rem;
    border-radius: 999px;
    background: linear-gradient(180deg, #ffe14a 0%, var(--bm-tstrip-yellow) 70%, #f3c800 100%);
    color: var(--bm-tstrip-ink);
    flex: 0 0 auto;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.55) inset,
      0 2px 6px rgba(255, 216, 1, 0.22);
  }

  #{{ section_id }} .bm-home-trust-strip__icon svg {
    width: 1.25rem;
    height: 1.25rem;
    display: block;
    fill: currentColor;
  }

  #{{ section_id }} .bm-home-trust-strip__content {
    min-width: 0;
  }

  #{{ section_id }} .bm-home-trust-strip__heading {
    margin: 0;
    color: var(--bm-tstrip-ink);
    font-size: clamp(0.97rem, 1.4vw, 1.05rem);
    line-height: 1.25;
    font-weight: 720;
    letter-spacing: 0;
  }

  #{{ section_id }} .bm-home-trust-strip__text {
    margin: 0.25rem 0 0;
    color: var(--bm-tstrip-muted);
    font-size: 0.9rem;
    line-height: 1.45;
    letter-spacing: 0;
  }

  @media screen and (min-width: 750px) {
    #{{ section_id }} .bm-home-trust-strip__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (min-width: 990px) {
    #{{ section_id }} .bm-home-trust-strip__grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
    }

    #{{ section_id }} .bm-home-trust-strip__item {
      padding: 1.15rem 1.2rem;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Baby Mood trust strip",
  "tag": "section",
  "class": "section section-bm-home-trust-strip",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section heading",
      "info": "Optional. Leave blank to hide."
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "chat", "label": "Consultation" },
            { "value": "leaf", "label": "Curated" },
            { "value": "return", "label": "Return" },
            { "value": "delivery", "label": "Delivery" },
            { "value": "shield", "label": "Safety" },
            { "value": "star", "label": "Quality" }
          ],
          "default": "chat"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Консултация преди поръчка"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Помагаме ви да изберете правилния модел за вашето дете."
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Baby Mood trust strip",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "icon": "chat",
            "heading": "Консултация преди поръчка",
            "text": "Помагаме ви да изберете правилния модел за вашето дете."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "leaf",
            "heading": "Подбрани детски мебели",
            "text": "Практични решения за уютна и спокойна детска стая."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "return",
            "heading": "14 дни право на връщане",
            "text": "Спокойна покупка за вашето семейство."
          }
        }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["index"]
  }
}
{% endschema %}
