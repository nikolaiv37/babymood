{% liquid
  assign s = section.settings
  assign overlay_alpha = s.overlay_opacity | divided_by: 100.0
%}

<div
  class="bm-home-hero color-{{ s.color_scheme }} gradient"
  style="
    --bm-hero-overlay-alpha: {{ overlay_alpha }};
    --bm-hero-padding-top: {{ s.padding_top }}px;
    --bm-hero-padding-bottom: {{ s.padding_bottom }}px;
  "
>
  <div class="bm-home-hero__inner">
    <div class="bm-home-hero__media" aria-hidden="{% if s.heading != blank %}true{% else %}false{% endif %}">
      {%- if s.image_desktop != blank -%}
        <img
          class="bm-home-hero__image bm-home-hero__image--desktop"
          src="{{ s.image_desktop | image_url: width: 2000 }}"
          srcset="
            {{ s.image_desktop | image_url: width: 800 }} 800w,
            {{ s.image_desktop | image_url: width: 1200 }} 1200w,
            {{ s.image_desktop | image_url: width: 1600 }} 1600w,
            {{ s.image_desktop | image_url: width: 2000 }} 2000w
          "
          sizes="(min-width: 990px) 100vw, 0"
          alt="{{ s.image_desktop.alt | default: s.heading | escape }}"
          loading="eager"
          fetchpriority="high"
          width="{{ s.image_desktop.width }}"
          height="{{ s.image_desktop.height }}"
        >
      {%- endif -%}
      {%- if s.image_mobile != blank -%}
        <img
          class="bm-home-hero__image bm-home-hero__image--mobile"
          src="{{ s.image_mobile | image_url: width: 1200 }}"
          srcset="
            {{ s.image_mobile | image_url: width: 600 }} 600w,
            {{ s.image_mobile | image_url: width: 900 }} 900w,
            {{ s.image_mobile | image_url: width: 1200 }} 1200w
          "
          sizes="(max-width: 989px) 100vw, 0"
          alt="{{ s.image_mobile.alt | default: s.heading | escape }}"
          loading="eager"
          fetchpriority="high"
          width="{{ s.image_mobile.width }}"
          height="{{ s.image_mobile.height }}"
        >
      {%- elsif s.image_desktop != blank -%}
        <img
          class="bm-home-hero__image bm-home-hero__image--mobile"
          src="{{ s.image_desktop | image_url: width: 1200 }}"
          srcset="
            {{ s.image_desktop | image_url: width: 600 }} 600w,
            {{ s.image_desktop | image_url: width: 900 }} 900w,
            {{ s.image_desktop | image_url: width: 1200 }} 1200w
          "
          sizes="(max-width: 989px) 100vw, 0"
          alt="{{ s.image_desktop.alt | default: s.heading | escape }}"
          loading="eager"
          fetchpriority="high"
          width="{{ s.image_desktop.width }}"
          height="{{ s.image_desktop.height }}"
        >
      {%- endif -%}
      <div class="bm-home-hero__overlay" aria-hidden="true"></div>
    </div>

    <div class="bm-home-hero__content">
      {%- if s.heading != blank -%}
        {%- assign hero_highlight = s.heading_highlight -%}
        {%- if hero_highlight != blank and s.heading contains hero_highlight -%}
          {%- capture hero_highlight_html -%}<span class="bm-home-hero__heading-highlight">{{ hero_highlight }}</span>{%- endcapture -%}
          {%- assign hero_heading_rendered = s.heading | replace_first: hero_highlight, hero_highlight_html -%}
          <h1 class="bm-home-hero__heading">{{ hero_heading_rendered }}</h1>
        {%- else -%}
          <h1 class="bm-home-hero__heading">{{ s.heading }}</h1>
        {%- endif -%}
      {%- endif -%}

      {%- if s.subheading != blank -%}
        <p class="bm-home-hero__subheading">{{ s.subheading }}</p>
      {%- endif -%}

      {%- if s.primary_label != blank or s.secondary_label != blank -%}
        <div class="bm-home-hero__actions">
          {%- if s.primary_label != blank -%}
            <a
              class="bm-home-hero__btn bm-home-hero__btn--primary"
              href="{{ s.primary_link | default: '#' }}"
            >
              {{ s.primary_label }}
            </a>
          {%- endif -%}
          {%- if s.secondary_label != blank -%}
            <a
              class="bm-home-hero__btn bm-home-hero__btn--secondary"
              href="{{ s.secondary_link | default: '#' }}"
            >
              {{ s.secondary_label }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if s.chip_1 != blank or s.chip_2 != blank or s.chip_3 != blank -%}
        <ul class="bm-home-hero__chips" role="list">
          {%- if s.chip_1 != blank -%}
            <li class="bm-home-hero__chip">
              <span class="bm-home-hero__chip-dot" aria-hidden="true"></span>
              {{ s.chip_1 }}
            </li>
          {%- endif -%}
          {%- if s.chip_2 != blank -%}
            <li class="bm-home-hero__chip">
              <span class="bm-home-hero__chip-dot" aria-hidden="true"></span>
              {{ s.chip_2 }}
            </li>
          {%- endif -%}
          {%- if s.chip_3 != blank -%}
            <li class="bm-home-hero__chip">
              <span class="bm-home-hero__chip-dot" aria-hidden="true"></span>
              {{ s.chip_3 }}
            </li>
          {%- endif -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .bm-home-hero {
    --bm-hero-yellow: #ffd801;
    --bm-hero-yellow-deep: #f3c800;
    --bm-hero-cream: #fffaf0;
    --bm-hero-cream-warm: #fff4dc;
    --bm-hero-ink: #2a2520;
    --bm-hero-muted: rgba(42, 37, 32, 0.7);
    --bm-hero-border: #efe6c8;
    --bm-hero-border-soft: rgba(239, 230, 200, 0.7);
    --bm-hero-radius: 28px;

    position: relative;
    padding-top: var(--bm-hero-padding-top, 24px);
    padding-bottom: var(--bm-hero-padding-bottom, 32px);
    padding-inline: clamp(12px, 4vw, 28px);
    color: var(--bm-hero-ink);
  }

  .bm-home-hero__inner {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    max-width: 1400px;
    margin: 0 auto;
    border-radius: var(--bm-hero-radius);
    background:
      radial-gradient(120% 90% at 100% 0%, rgba(255, 216, 1, 0.08), transparent 55%),
      linear-gradient(180deg, #fffdf6, var(--bm-hero-cream));
    overflow: hidden;
    box-shadow: 0 4px 14px rgba(47, 42, 38, 0.04);
    border: 1px solid var(--bm-hero-border-soft);
  }

  .bm-home-hero__media {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--bm-hero-cream);
  }

  .bm-home-hero__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(1.06) contrast(1.02);
  }

  .bm-home-hero__image--desktop {
    display: none;
  }

  /* Softer, less washed-out overlay: gentle warm vignette + subtle yellow corner glow */
  .bm-home-hero__overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(80% 60% at 0% 0%, rgba(255, 216, 1, calc(var(--bm-hero-overlay-alpha) * 0.35)), transparent 60%),
      radial-gradient(120% 90% at 100% 100%, rgba(255, 244, 220, calc(var(--bm-hero-overlay-alpha) * 0.35)), transparent 65%);
    mix-blend-mode: multiply;
  }

  .bm-home-hero__content {
    position: relative;
    padding: 1.4rem 1.4rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    align-items: flex-start;
  }

  /* Subtle playful Baby Mood accents — pure CSS, no markup change */
  .bm-home-hero__content::before {
    content: "";
    position: absolute;
    top: 1.1rem;
    right: 1.3rem;
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: var(--bm-hero-yellow);
    box-shadow: 0 0 0 5px rgba(255, 216, 1, 0.18);
    pointer-events: none;
  }

  .bm-home-hero__content::after {
    content: "";
    position: absolute;
    bottom: -22px;
    right: -28px;
    width: 140px;
    height: 140px;
    border-radius: 999px;
    background: radial-gradient(circle at 35% 35%, rgba(255, 216, 1, 0.16), transparent 65%);
    pointer-events: none;
  }

  .bm-home-hero__heading {
    margin: 0;
    font-size: clamp(1.6rem, 4.6vw, 2.1rem);
    line-height: 1.12;
    font-weight: 780;
    letter-spacing: -0.012em;
    color: var(--bm-hero-ink);
    text-wrap: balance;
  }

  .bm-home-hero__heading-highlight {
    color: #c99700;
    background: linear-gradient(135deg, #c99700 0%, #e9b500 50%, #d6a300 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .bm-home-hero__subheading {
    margin: 0;
    font-size: clamp(0.97rem, 2.6vw, 1.07rem);
    line-height: 1.5;
    color: var(--bm-hero-muted);
    max-width: 52ch;
  }

  .bm-home-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 0.3rem;
  }

  .bm-home-hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0.78rem 1.3rem;
    border-radius: 999px;
    font-size: 0.97rem;
    font-weight: 750;
    line-height: 1.1;
    letter-spacing: 0.005em;
    text-decoration: none;
    transition: transform 0.18s ease, box-shadow 0.22s ease, background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    border: 1px solid transparent;
    will-change: transform;
  }

  .bm-home-hero__btn--primary {
    background: linear-gradient(180deg, #ffe14a 0%, var(--bm-hero-yellow) 55%, var(--bm-hero-yellow-deep) 100%);
    color: var(--bm-hero-ink);
    border-color: rgba(47, 42, 38, 0.06);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.55) inset,
      0 2px 0 rgba(47, 42, 38, 0.06),
      0 6px 16px rgba(255, 216, 1, 0.22);
  }

  .bm-home-hero__btn--primary:hover {
    transform: translateY(-1px);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.6) inset,
      0 3px 0 rgba(47, 42, 38, 0.07),
      0 10px 22px rgba(255, 216, 1, 0.3);
  }

  .bm-home-hero__btn--primary:active {
    transform: translateY(0);
  }

  .bm-home-hero__btn--secondary {
    background: rgba(255, 255, 255, 0.85);
    color: var(--bm-hero-ink);
    border-color: var(--bm-hero-border);
    backdrop-filter: saturate(1.1);
  }

  .bm-home-hero__btn--secondary:hover {
    background: #ffffff;
    border-color: #e6d9a6;
  }

  .bm-home-hero__chips {
    list-style: none;
    padding: 0;
    margin: 0.55rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .bm-home-hero__chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    background: linear-gradient(180deg, #ffffff, var(--bm-hero-cream-warm));
    border: 1px solid var(--bm-hero-border);
    color: var(--bm-hero-ink);
    font-size: 0.8rem;
    line-height: 1.2;
    font-weight: 650;
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.6) inset;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }

  .bm-home-hero__chip:hover {
    transform: translateY(-1px);
    border-color: #e6d9a6;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.6) inset,
      0 4px 10px rgba(255, 216, 1, 0.12);
  }

  .bm-home-hero__chip-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: var(--bm-hero-yellow);
    box-shadow:
      0 0 0 3px rgba(255, 216, 1, 0.22),
      0 0 0 4px rgba(255, 216, 1, 0.08);
    flex: 0 0 auto;
  }

  @media screen and (min-width: 750px) {
    .bm-home-hero__content {
      padding: 1.8rem 1.8rem 2rem;
      gap: 1.05rem;
    }
  }

  @media screen and (min-width: 990px) {
    .bm-home-hero__inner {
      grid-template-columns: 1.05fr 1fr;
      align-items: stretch;
    }

    .bm-home-hero__media {
      aspect-ratio: auto;
      min-height: 500px;
      height: 100%;
    }

    .bm-home-hero__image--mobile {
      display: none;
    }

    .bm-home-hero__image--desktop {
      display: block;
    }

    .bm-home-hero__content {
      padding: 3.2rem 3rem;
      justify-content: center;
      gap: 1.2rem;
    }

    .bm-home-hero__content::before {
      top: 2rem;
      right: 2rem;
      width: 0.65rem;
      height: 0.65rem;
    }

    .bm-home-hero__content::after {
      width: 220px;
      height: 220px;
      bottom: -40px;
      right: -50px;
    }

    .bm-home-hero__heading {
      font-size: clamp(2.05rem, 2.7vw, 2.7rem);
    }

    .bm-home-hero__subheading {
      font-size: 1.08rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Baby Mood home hero",
  "tag": "section",
  "class": "section section-bm-home-hero",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Copy"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Монтесори легла и детски мебели за уютна детска стая"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Highlighted phrase",
      "info": "If this phrase appears in the heading, it is rendered in warm gold.",
      "default": "Монтесори легла"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Подбрани модели за спокойна рутина, повече самостоятелност и практично обзавеждане у дома."
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Разгледай Монтесори легла"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Виж всички продукти"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "header",
      "content": "Trust chips"
    },
    {
      "type": "text",
      "id": "chip_1",
      "label": "Chip 1",
      "default": "Подбрани модели"
    },
    {
      "type": "text",
      "id": "chip_2",
      "label": "Chip 2",
      "default": "Безопасен избор"
    },
    {
      "type": "text",
      "id": "chip_3",
      "label": "Chip 3",
      "default": "Консултация преди покупка"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image",
      "info": "Falls back to desktop image if empty."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "presets": [
    {
      "name": "Baby Mood home hero"
    }
  ],
  "enabled_on": {
    "templates": ["index"]
  }
}
{% endschema %}
