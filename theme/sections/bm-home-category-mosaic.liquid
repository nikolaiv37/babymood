{% liquid
  assign section_id = 'bm-home-category-mosaic-' | append: section.id
%}

<section
  id="{{ section_id }}"
  class="bm-home-category-mosaic color-{{ section.settings.color_scheme }} gradient"
>
  <div class="bm-home-category-mosaic__inner">
    {% if section.settings.heading != blank or section.settings.subheading != blank %}
      <div class="bm-home-category-mosaic__intro">
        {% if section.settings.heading != blank %}
          <h2 class="bm-home-category-mosaic__heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <p class="bm-home-category-mosaic__subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="bm-home-category-mosaic__grid">
      {% for block in section.blocks %}
        {%- assign tile_size = block.settings.size | default: 'small' -%}
        {%- assign tile_alt = block.settings.image.alt | default: block.settings.title | escape -%}
        {%- capture tile_inner -%}
          <div class="bm-home-category-mosaic__media">
            {%- if block.settings.image != blank -%}
              <img
                class="bm-home-category-mosaic__image"
                src="{{ block.settings.image | image_url: width: 1400 }}"
                srcset="
                  {{ block.settings.image | image_url: width: 600 }} 600w,
                  {{ block.settings.image | image_url: width: 900 }} 900w,
                  {{ block.settings.image | image_url: width: 1200 }} 1200w,
                  {{ block.settings.image | image_url: width: 1600 }} 1600w
                "
                sizes="(min-width: 990px) {% if tile_size == 'large' %}50vw{% else %}25vw{% endif %}, (min-width: 750px) 50vw, 100vw"
                alt="{{ tile_alt }}"
                loading="lazy"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
              >
            {%- else -%}
              <div class="bm-home-category-mosaic__image bm-home-category-mosaic__image--placeholder" aria-hidden="true"></div>
            {%- endif -%}
            <div class="bm-home-category-mosaic__overlay" aria-hidden="true"></div>
          </div>

          <div class="bm-home-category-mosaic__content">
            {% if block.settings.title != blank %}
              <span class="bm-home-category-mosaic__pill">{{ block.settings.title }}</span>
            {% endif %}
            {% if block.settings.subtitle != blank %}
              <p class="bm-home-category-mosaic__text">{{ block.settings.subtitle }}</p>
            {% endif %}
            <span class="bm-home-category-mosaic__cta" aria-hidden="true">
              <span class="bm-home-category-mosaic__cta-label">Разгледай</span>
              <svg viewBox="0 0 24 24" focusable="false">
                <path d="M13.3 5.6 19.7 12l-6.4 6.4-1.4-1.4 4-4H4v-2h11.9l-4-4 1.4-1.4Z" />
              </svg>
            </span>
          </div>
        {%- endcapture -%}

        {% if block.settings.link != blank %}
          <a
            href="{{ block.settings.link }}"
            class="bm-home-category-mosaic__tile bm-home-category-mosaic__tile--{{ tile_size }}"
            aria-label="{{ block.settings.title | escape }}"
            {{ block.shopify_attributes }}
          >
            {{ tile_inner }}
          </a>
        {% else %}
          <div
            class="bm-home-category-mosaic__tile bm-home-category-mosaic__tile--{{ tile_size }}"
            {{ block.shopify_attributes }}
          >
            {{ tile_inner }}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.button_label != blank %}
      <div class="bm-home-category-mosaic__footer">
        <a
          class="bm-home-category-mosaic__button"
          href="{{ section.settings.button_link | default: '#' }}"
        >
          {{ section.settings.button_label }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

{% style %}
  #{{ section_id }} {
    --bm-mos-ink: #2a2520;
    --bm-mos-muted: rgba(42, 37, 32, 0.72);
    --bm-mos-yellow: #ffd801;
    --bm-mos-yellow-deep: #f3c800;
    --bm-mos-cream: #fffdf6;
    --bm-mos-cream-warm: #fff4dc;
    --bm-mos-border: #efe6c8;
    --bm-mos-border-soft: rgba(239, 230, 200, 0.7);
    --bm-mos-radius: 22px;
    --bm-mos-gap: clamp(0.6rem, 1.6vw, 1rem);
    padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px;
    padding-inline: clamp(12px, 4vw, 28px);
    color: var(--bm-mos-ink);
  }

  #{{ section_id }} .bm-home-category-mosaic__inner {
    max-width: 1400px;
    margin: 0 auto;
  }

  #{{ section_id }} .bm-home-category-mosaic__intro {
    text-align: center;
    margin-bottom: clamp(1rem, 2.4vw, 1.6rem);
  }

  #{{ section_id }} .bm-home-category-mosaic__heading {
    margin: 0;
    font-size: clamp(1.5rem, 3.4vw, 2rem);
    line-height: 1.15;
    font-weight: 760;
    letter-spacing: -0.008em;
    color: var(--bm-mos-ink);
    text-wrap: balance;
  }

  #{{ section_id }} .bm-home-category-mosaic__subheading {
    margin: 0.4rem auto 0;
    max-width: 52ch;
    font-size: clamp(0.95rem, 1.8vw, 1.02rem);
    line-height: 1.5;
    color: var(--bm-mos-muted);
  }

  #{{ section_id }} .bm-home-category-mosaic__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--bm-mos-gap);
  }

  #{{ section_id }} .bm-home-category-mosaic__tile {
    position: relative;
    display: block;
    overflow: hidden;
    min-height: 240px;
    border-radius: var(--bm-mos-radius);
    border: 1px solid var(--bm-mos-border-soft);
    background: var(--bm-mos-cream);
    color: var(--bm-mos-ink);
    text-decoration: none;
    isolation: isolate;
    transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
  }

  #{{ section_id }} a.bm-home-category-mosaic__tile:hover {
    transform: translateY(-2px);
    border-color: #e6d9a6;
    box-shadow: 0 10px 24px rgba(47, 42, 38, 0.08);
  }

  #{{ section_id }} a.bm-home-category-mosaic__tile:hover .bm-home-category-mosaic__image {
    transform: scale(1.03);
  }

  #{{ section_id }} a.bm-home-category-mosaic__tile:hover .bm-home-category-mosaic__cta {
    background: var(--bm-mos-yellow);
    border-color: rgba(47, 42, 38, 0.1);
  }

  #{{ section_id }} a.bm-home-category-mosaic__tile:focus-visible {
    outline: 2px solid var(--bm-mos-yellow);
    outline-offset: 3px;
  }

  #{{ section_id }} .bm-home-category-mosaic__media {
    position: absolute;
    inset: 0;
    overflow: hidden;
    border-radius: inherit;
  }

  #{{ section_id }} .bm-home-category-mosaic__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
    filter: saturate(1.05);
  }

  #{{ section_id }} .bm-home-category-mosaic__image--placeholder {
    background:
      radial-gradient(circle at 30% 30%, rgba(255, 216, 1, 0.28), transparent 55%),
      linear-gradient(140deg, var(--bm-mos-cream-warm), var(--bm-mos-cream));
  }

  #{{ section_id }} .bm-home-category-mosaic__overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(180deg, rgba(42, 37, 32, 0) 45%, rgba(42, 37, 32, 0.42) 100%),
      radial-gradient(80% 60% at 100% 0%, rgba(255, 216, 1, 0.18), transparent 60%);
  }

  #{{ section_id }} .bm-home-category-mosaic__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.4rem;
    padding: 1rem 1.1rem 1.05rem;
    height: 100%;
    justify-content: flex-end;
  }

  #{{ section_id }} .bm-home-category-mosaic__pill {
    display: inline-flex;
    align-items: center;
    padding: 0.36rem 0.7rem;
    border-radius: 999px;
    background: rgba(255, 253, 246, 0.95);
    border: 1px solid var(--bm-mos-border);
    color: var(--bm-mos-ink);
    font-size: 0.92rem;
    font-weight: 720;
    line-height: 1.15;
    letter-spacing: -0.005em;
    backdrop-filter: saturate(1.1);
  }

  #{{ section_id }} .bm-home-category-mosaic__text {
    margin: 0;
    color: #fffdf6;
    font-size: 0.86rem;
    line-height: 1.4;
    max-width: 36ch;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.25);
  }

  #{{ section_id }} .bm-home-category-mosaic__cta {
    position: absolute;
    top: 0.9rem;
    right: 0.9rem;
    display: inline-flex;
    align-items: center;
    gap: 0.32rem;
    padding: 0.34rem 0.6rem 0.34rem 0.75rem;
    border-radius: 999px;
    background: rgba(255, 253, 246, 0.92);
    border: 1px solid var(--bm-mos-border);
    color: var(--bm-mos-ink);
    font-size: 0.78rem;
    font-weight: 700;
    transition: background-color 0.18s ease, border-color 0.18s ease;
  }

  #{{ section_id }} .bm-home-category-mosaic__cta-label {
    line-height: 1;
  }

  #{{ section_id }} .bm-home-category-mosaic__cta svg {
    width: 0.95rem;
    height: 0.95rem;
    fill: currentColor;
    display: block;
  }

  #{{ section_id }} .bm-home-category-mosaic__footer {
    margin-top: clamp(1rem, 2.4vw, 1.4rem);
    display: flex;
    justify-content: center;
  }

  #{{ section_id }} .bm-home-category-mosaic__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0.7rem 1.2rem;
    border-radius: 999px;
    background: linear-gradient(180deg, #ffe14a 0%, var(--bm-mos-yellow) 55%, var(--bm-mos-yellow-deep) 100%);
    color: var(--bm-mos-ink);
    font-size: 0.95rem;
    font-weight: 740;
    text-decoration: none;
    border: 1px solid rgba(47, 42, 38, 0.06);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.55) inset,
      0 2px 0 rgba(47, 42, 38, 0.06),
      0 6px 16px rgba(255, 216, 1, 0.22);
    transition: transform 0.18s ease, box-shadow 0.22s ease;
  }

  #{{ section_id }} .bm-home-category-mosaic__button:hover {
    transform: translateY(-1px);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.6) inset,
      0 3px 0 rgba(47, 42, 38, 0.07),
      0 10px 22px rgba(255, 216, 1, 0.3);
  }

  /* Tablet: 2 columns, large spans both */
  @media screen and (min-width: 750px) {
    #{{ section_id }} .bm-home-category-mosaic__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-auto-rows: minmax(220px, auto);
    }

    #{{ section_id }} .bm-home-category-mosaic__tile {
      min-height: 260px;
    }

    #{{ section_id }} .bm-home-category-mosaic__tile--large {
      grid-column: span 2;
      min-height: 320px;
    }
  }

  /* Desktop mosaic: 12-column grid */
  @media screen and (min-width: 990px) {
    #{{ section_id }} .bm-home-category-mosaic__grid {
      grid-template-columns: repeat(12, minmax(0, 1fr));
      grid-auto-rows: minmax(220px, auto);
      grid-auto-flow: dense;
    }

    #{{ section_id }} .bm-home-category-mosaic__tile {
      grid-column: span 4;
      grid-row: span 1;
      min-height: 240px;
    }

    #{{ section_id }} .bm-home-category-mosaic__tile--small {
      grid-column: span 3;
    }

    #{{ section_id }} .bm-home-category-mosaic__tile--wide {
      grid-column: span 6;
    }

    #{{ section_id }} .bm-home-category-mosaic__tile--large {
      grid-column: span 6;
      grid-row: span 2;
      min-height: 100%;
    }

    #{{ section_id }} .bm-home-category-mosaic__content {
      padding: 1.2rem 1.3rem 1.25rem;
    }

    #{{ section_id }} .bm-home-category-mosaic__pill {
      font-size: 1rem;
      padding: 0.42rem 0.85rem;
    }

    #{{ section_id }} .bm-home-category-mosaic__text {
      font-size: 0.92rem;
      max-width: 42ch;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Baby Mood category mosaic",
  "tag": "section",
  "class": "section section-bm-home-category-mosaic",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Copy"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Разгледай категории"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Подбрани продукти за уютна, практична и спокойна детска стая."
    },
    {
      "type": "header",
      "content": "Footer button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Виж всички продукти"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "category_tile",
      "name": "Category tile",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Категория"
        },
        {
          "type": "textarea",
          "id": "subtitle",
          "label": "Short text"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "select",
          "id": "size",
          "label": "Tile size (desktop)",
          "options": [
            { "value": "large", "label": "Large (feature)" },
            { "value": "wide", "label": "Wide" },
            { "value": "small", "label": "Small" }
          ],
          "default": "small"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Baby Mood category mosaic",
      "blocks": [
        {
          "type": "category_tile",
          "settings": {
            "title": "Монтесори легла",
            "subtitle": "Ниски легла за повече самостоятелност и спокойна вечерна рутина.",
            "size": "large"
          }
        },
        {
          "type": "category_tile",
          "settings": {
            "title": "Детски легла",
            "subtitle": "Практични модели за удобен сън и уютна детска стая.",
            "size": "wide"
          }
        },
        {
          "type": "category_tile",
          "settings": {
            "title": "Допълващи мебели",
            "subtitle": "Малки решения, които правят стаята по-подредена и удобна.",
            "size": "small"
          }
        },
        {
          "type": "category_tile",
          "settings": {
            "title": "Детски лампи",
            "subtitle": "Меки акценти за по-топла и приятна атмосфера.",
            "size": "small"
          }
        }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["index"]
  }
}
{% endschema %}
