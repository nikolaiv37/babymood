{% liquid
  assign block_settings = block.settings
%}

<div
  class="bm-free-delivery-notice"
  {{ block.shopify_attributes }}
>
  <div class="bm-free-delivery-notice__icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" focusable="false">
      <path d="M3 5.2h11.8v3h2.6l3.6 4.2v5.2h-2.2a3 3 0 0 1-5.8 0H9.8a3 3 0 0 1-5.8 0H3V5.2Zm2.3 2.3v7.6h.4a3 3 0 0 1 3.8 0h5.3V7.5H5.3Zm11.8 3v4.6h1.6v-1.8l-2.4-2.8h.8ZM6.9 18.7a.9.9 0 1 0 0-1.8.9.9 0 0 0 0 1.8Zm9 0a.9.9 0 1 0 0-1.8.9.9 0 0 0 0 1.8Z" />
    </svg>
  </div>
  <div class="bm-free-delivery-notice__content">
    {% if block_settings.title != blank %}
      <p class="bm-free-delivery-notice__title">{{ block_settings.title }}</p>
    {% endif %}
    {% if block_settings.text != blank %}
      <p class="bm-free-delivery-notice__text">{{ block_settings.text }}</p>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .bm-free-delivery-notice {
    --bm-fd-bg: #eaf7ef;
    --bm-fd-border: #cdedd8;
    --bm-fd-accent: #21805a;
    --bm-fd-ink: #1b5a40;
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 0.65rem;
    width: 100%;
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--bm-fd-border);
    border-radius: 14px;
    background: var(--bm-fd-bg);
    color: var(--bm-fd-ink);
  }

  .bm-free-delivery-notice__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.9rem;
    height: 1.9rem;
    border-radius: 10px;
    background: #ffffff;
    border: 1px solid var(--bm-fd-border);
    color: var(--bm-fd-accent);
    flex: 0 0 auto;
  }

  .bm-free-delivery-notice__icon svg {
    display: block;
    width: 1.05rem;
    height: 1.05rem;
    fill: currentColor;
  }

  .bm-free-delivery-notice__content {
    min-width: 0;
  }

  .bm-free-delivery-notice__title {
    margin: 0;
    color: var(--bm-fd-accent);
    font-size: 0.88rem;
    line-height: 1.2;
    font-weight: 750;
    letter-spacing: 0;
  }

  .bm-free-delivery-notice__text {
    margin: 0.12rem 0 0;
    color: var(--bm-fd-ink);
    font-size: 0.78rem;
    line-height: 1.3;
    letter-spacing: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "BM free delivery notice",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Безплатна доставка"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Безплатна доставка до офис на Еконт за всяка поръчка от Baby Mood."
    }
  ],
  "presets": [
    {
      "name": "BM free delivery notice"
    }
  ]
}
{% endschema %}
