    <div class="bm-cta-reassurance__item">
      <div class="bm-cta-reassurance__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <path d="M12 4a8 8 0 1 1-7.3 11.3l2.2-1A5.6 5.6 0 1 0 7.4 9h2.1v2.4H3.1V5h2.4v2A8 8 0 0 1 12 4Zm1.1 4.1v4.1l3 1.8-1.1 1.9-4.2-2.5V8.1h2.3Z" />
        </svg>
      </div>
      <div class="bm-cta-reassurance__content">
        {% if block_settings.heading_1 != blank %}
          <p class="bm-cta-reassurance__heading">{{ block_settings.heading_1 }}</p>
        {% endif %}
        {% if block_settings.text_1 != blank %}
          <p class="bm-cta-reassurance__text">{{ block_settings.text_1 }}</p>
        {% endif %}
      </div>
    </div>

    <div class="bm-cta-reassurance__item">
      <div class="bm-cta-reassurance__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <path d="M4.5 5.5h15A2.5 2.5 0 0 1 22 8v8a2.5 2.5 0 0 1-2.5 2.5h-15A2.5 2.5 0 0 1 2 16V8a2.5 2.5 0 0 1 2.5-2.5Zm0 2.3a.2.2 0 0 0-.2.2v1.1h15.4V8a.2.2 0 0 0-.2-.2h-15Zm-.2 5v3.2c0 .1.1.2.2.2h15c.1 0 .2-.1.2-.2v-3.2H4.3Zm2 1.2h5v2h-5v-2Z" />
        </svg>
      </div>
      <div class="bm-cta-reassurance__content">
        {% if block_settings.heading_2 != blank %}
          <p class="bm-cta-reassurance__heading">{{ block_settings.heading_2 }}</p>
        {% endif %}
        {% if block_settings.text_2 != blank %}
          <p class="bm-cta-reassurance__text">{{ block_settings.text_2 }}</p>
        {% endif %}
      </div>
    </div>

    <div class="bm-cta-reassurance__item">
      <div class="bm-cta-reassurance__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <path d="M12 2.8 20 6v5.6c0 5-3.3 8.5-8 9.8-4.7-1.3-8-4.8-8-9.8V6l8-3.2Zm0 2.6L6.4 7.6v4c0 3.6 2.2 6.1 5.6 7.2 3.4-1.1 5.6-3.6 5.6-7.2v-4L12 5.4Zm3.9 5.2-4.8 4.8-2.8-2.8 1.6-1.6 1.2 1.2 3.2-3.2 1.6 1.6Z" />
        </svg>
      </div>
      <div class="bm-cta-reassurance__content">
        {% if block_settings.heading_3 != blank %}
          <p class="bm-cta-reassurance__heading">{{ block_settings.heading_3 }}</p>
        {% endif %}
        {% if block_settings.text_3 != blank %}
          <p class="bm-cta-reassurance__text">{{ block_settings.text_3 }}</p>
        {% endif %}
      </div>
    </div>

    <div class="bm-cta-reassurance__item">
      <div class="bm-cta-reassurance__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <path d="M9 2h6c.83 0 1.5.5 1.79 1.2H19a2 2 0 0 1 2 2v15a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-15a2 2 0 0 1 2-2h2.21C7.5 2.5 8.17 2 9 2Zm0 2v2h6V4H9ZM5 7.2v13h14V7.2h-2v.6c0 .4-.3.7-.7.7H7.7a.7.7 0 0 1-.7-.7v-.6H5Zm6.1 5.7-2.4 2.4-1.4-1.4-1.4 1.4 2.8 2.8 3.8-3.8-1.4-1.4Z" />
        </svg>
      </div>
      <div class="bm-cta-reassurance__content">
        {% if block_settings.heading_4 != blank %}
          <p class="bm-cta-reassurance__heading">{{ block_settings.heading_4 }}</p>
        {% endif %}
        {% if block_settings.text_4 != blank %}
          <p class="bm-cta-reassurance__text">{{ block_settings.text_4 }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .bm-cta-reassurance {
    --bm-cta-ink: #2f2a26;
    --bm-cta-yellow: #ffd801;
    --bm-cta-border: #efe6c8;
    --bm-cta-cream: #fffdf5;
    --bm-cta-muted: rgba(47, 42, 38, 0.7);
    color: var(--bm-cta-ink);
    width: 100%;
  }

  .bm-cta-reassurance__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.55rem;
  }

  .bm-cta-reassurance__item {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 0.65rem;
    min-width: 0;
    padding: 0.68rem 0.74rem;
    border: 1px solid var(--bm-cta-border);
    border-radius: 16px;
    background:
      linear-gradient(145deg, rgba(255, 253, 245, 0.96), rgba(255, 255, 255, 0.98)),
      #ffffff;
    box-shadow: 0 3px 10px rgba(47, 42, 38, 0.028);
    overflow: hidden;
  }

  .bm-cta-reassurance__item::after {
    content: "";
    position: absolute;
    top: 0.55rem;
    right: 0.58rem;
    width: 0.34rem;
    height: 0.34rem;
    border-radius: 999px;
    background: rgba(255, 216, 1, 0.4);
    pointer-events: none;
  }

  .bm-cta-reassurance__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border: 1px solid rgba(239, 230, 200, 0.95);
    border-radius: 12px;
    background:
      radial-gradient(circle at 35% 25%, rgba(255, 216, 1, 0.38), transparent 58%),
      var(--bm-cta-cream);
    color: var(--bm-cta-ink);
    flex: 0 0 auto;
  }

  .bm-cta-reassurance__icon svg {
    display: block;
    width: 1.05rem;
    height: 1.05rem;
    fill: currentColor;
  }

  .bm-cta-reassurance__content {
    min-width: 0;
  }

  .bm-cta-reassurance__heading {
    margin: 0;
    color: var(--bm-cta-ink);
    font-size: 0.86rem;
    line-height: 1.18;
    font-weight: 750;
    letter-spacing: 0;
  }

  .bm-cta-reassurance__text {
    margin: 0.14rem 0 0;
    color: var(--bm-cta-muted);
    font-size: 0.78rem;
    line-height: 1.28;
    letter-spacing: 0;
  }

  @media screen and (min-width: 420px) {
    .bm-cta-reassurance__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
{% endstylesheet %}

